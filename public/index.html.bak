<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>xprocessmanager</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #0f1117;
      --surface: #1a1d27;
      --surface2: #242734;
      --border: #2e3144;
      --text: #e1e4ed;
      --text-dim: #8b8fa3;
      --green: #34d399;
      --red: #f87171;
      --yellow: #fbbf24;
      --blue: #60a5fa;
      --purple: #a78bfa;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
    }

    header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 16px 24px;
      border-bottom: 1px solid var(--border);
      background: var(--surface);
    }

    header h1 {
      font-size: 18px;
      font-weight: 600;
      letter-spacing: -0.3px;
    }

    .header-actions { display: flex; gap: 8px; align-items: center; }

    .btn-settings-icon {
      padding: 7px 10px;
      line-height: 0;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }
    .btn-settings-icon svg {
      display: block;
    }

    button {
      border: none;
      border-radius: 6px;
      padding: 7px 14px;
      font-size: 13px;
      font-weight: 500;
      cursor: pointer;
      transition: opacity 0.15s;
    }
    button:hover { opacity: 0.85; }
    button:active { opacity: 0.7; }

    .btn-start { background: var(--green); color: #000; }
    .btn-stop { background: var(--red); color: #000; }
    .btn-restart { background: var(--blue); color: #000; }
    .btn-ghost {
      background: var(--surface2);
      color: var(--text-dim);
      border: 1px solid var(--border);
    }

    .container { padding: 20px 24px; }

    .group-title {
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: var(--text-dim);
      margin: 20px 0 8px;
    }
    .group-title:first-child { margin-top: 0; }

    .process-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
      gap: 10px;
    }

    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 14px 16px;
      transition: border-color 0.15s, box-shadow 0.15s;
      cursor: pointer;
    }
    .card:hover:not(.selected) {
      box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.1);
    }
    .card.selected {
      border-color: var(--blue) !important;
    }

    .card-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 8px;
    }

    .card-name {
      font-size: 14px;
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .status-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      display: inline-block;
      flex-shrink: 0;
    }
    .status-dot.running { background: var(--green); box-shadow: 0 0 6px var(--green); }
    .status-dot.stopped { background: var(--text-dim); }
    .status-dot.errored { background: var(--red); box-shadow: 0 0 6px var(--red); }
    .status-dot.stopping { background: var(--yellow); }

    .card-meta {
      font-size: 11px;
      color: var(--text-dim);
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
    }

    .branch-tag {
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 1px 6px;
      font-size: 11px;
      font-family: 'SF Mono', 'Fira Code', monospace;
      color: var(--purple);
    }

    .card-actions {
      display: flex;
      gap: 4px;
    }

    .card-actions button {
      padding: 4px 10px;
      font-size: 12px;
    }

    .log-panel {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      height: 300px;
      background: var(--surface);
      border-top: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      transition: transform 0.2s;
      z-index: 10;
    }
    .log-panel.hidden { transform: translateY(100%); }
    .log-panel.dragging { transition: none; }

    .log-resize-handle {
      position: absolute;
      top: -4px;
      left: 0;
      right: 0;
      height: 8px;
      cursor: ns-resize;
      z-index: 11;
    }
    .log-resize-handle::after {
      content: '';
      display: block;
      width: 40px;
      height: 3px;
      margin: 3px auto 0;
      border-radius: 2px;
      background: var(--border);
      transition: background 0.15s;
    }
    .log-resize-handle:hover::after { background: var(--text-dim); }

    .log-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 8px 16px;
      border-bottom: 1px solid var(--border);
      flex-shrink: 0;
    }

    .log-header span {
      font-size: 13px;
      font-weight: 600;
    }

    .log-body {
      flex: 1;
      overflow-y: auto;
      padding: 8px 16px;
      font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', monospace;
      font-size: 12px;
      line-height: 1.6;
    }

    .log-line { white-space: pre-wrap; word-break: break-all; }
    .log-line.stderr { color: var(--red); }
    .log-line.system { color: var(--yellow); font-style: italic; }

    .summary-bar {
      display: flex;
      gap: 16px;
      font-size: 13px;
      color: var(--text-dim);
    }
    .summary-bar .count { font-weight: 600; }
    .summary-bar .running-count { color: var(--green); }
    .summary-bar .stopped-count { color: var(--text-dim); }
    .summary-bar .errored-count { color: var(--red); }


    .modal-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.6);
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 20;
    }
    .modal-overlay.hidden { display: none; }

    .modal {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 24px;
      width: 440px;
      max-width: 90vw;
    }

    .modal h2 {
      font-size: 16px;
      font-weight: 600;
      margin-bottom: 16px;
    }

    .form-group {
      margin-bottom: 12px;
    }

    .form-group label {
      display: block;
      font-size: 12px;
      font-weight: 500;
      color: var(--text-dim);
      margin-bottom: 4px;
    }

    .form-group input, .form-group select {
      width: 100%;
      padding: 8px 10px;
      border-radius: 6px;
      border: 1px solid var(--border);
      background: var(--surface2);
      color: var(--text);
      font-size: 13px;
      font-family: inherit;
      outline: none;
    }
    .form-group input:focus, .form-group select:focus {
      border-color: var(--blue);
    }

    .form-group .hint {
      font-size: 11px;
      color: var(--text-dim);
      margin-top: 2px;
    }

    .modal-actions {
      display: flex;
      justify-content: flex-end;
      gap: 8px;
      margin-top: 18px;
    }

    .btn-delete {
      background: transparent;
      color: var(--red);
      border: 1px solid var(--border);
      padding: 7px 14px;
      font-size: 13px;
      font-weight: 500;
    }
    .btn-delete:hover { border-color: var(--red); }

    .btn-gear {
      background: transparent;
      color: var(--text-dim);
      border: 1px solid var(--border);
      padding: 4px 6px;
      line-height: 0;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }
    .btn-gear:hover { color: var(--text); border-color: #444860; }

    .env-rows { margin-bottom: 12px; }

    .env-row {
      display: flex;
      gap: 6px;
      margin-bottom: 6px;
      align-items: center;
    }

    .env-row input {
      padding: 7px 9px;
      border-radius: 6px;
      border: 1px solid var(--border);
      background: var(--surface2);
      color: var(--text);
      font-size: 12px;
      font-family: 'SF Mono', 'Fira Code', monospace;
      outline: none;
    }
    .env-row input:focus { border-color: var(--blue); }
    .env-row input.env-key { width: 160px; }
    .env-row input.env-val { flex: 1; }
    .group-rows .env-row input.env-val { font-family: inherit; }
    .group-row input[type="color"].group-color {
      width: 36px;
      height: 28px;
      padding: 2px;
      border: 1px solid var(--border);
      border-radius: 4px;
      cursor: pointer;
      flex-shrink: 0;
      background: var(--surface2);
    }

    .env-note code {
      font-size: 11px;
      padding: 1px 5px;
      background: var(--surface2);
      border-radius: 4px;
    }

    .env-row .btn-remove-row {
      background: transparent;
      color: var(--text-dim);
      border: none;
      padding: 4px 6px;
      font-size: 14px;
      line-height: 1;
      cursor: pointer;
    }
    .env-row .btn-remove-row:hover { color: var(--red); }

    .btn-add-row {
      background: transparent;
      color: var(--blue);
      border: 1px dashed var(--border);
      border-radius: 6px;
      padding: 6px 12px;
      font-size: 12px;
      width: 100%;
      cursor: pointer;
    }
    .btn-add-row:hover { border-color: var(--blue); }

    .env-note {
      font-size: 11px;
      color: var(--text-dim);
      margin-bottom: 14px;
    }

    .modal-wide { width: 540px; }
    .settings-tabs {
      display: flex;
      gap: 0;
      border-bottom: 1px solid var(--border);
      margin-bottom: 4px;
    }
    .settings-tab {
      padding: 8px 16px;
      font-size: 13px;
      font-weight: 500;
      color: var(--text-dim);
      cursor: pointer;
      border-bottom: 2px solid transparent;
      transition: color 0.15s, border-color 0.15s;
      background: none;
      border-top: none;
      border-left: none;
      border-right: none;
    }
    .settings-tab:hover { color: var(--text); }
    .settings-tab.active {
      color: var(--text);
      border-bottom-color: var(--accent, #60a5fa);
    }
    .settings-tab-content { display: none; }
    .settings-tab-content.active { display: block; }
    .setting-field { margin-bottom: 14px; }
    .setting-field label {
      display: block;
      font-size: 12px;
      font-weight: 500;
      color: var(--text-dim);
      margin-bottom: 4px;
    }
    .setting-field input[type="number"] {
      width: 120px;
      padding: 6px 8px;
      border-radius: 6px;
      border: 1px solid var(--border);
      background: var(--bg);
      color: var(--text);
      font-size: 13px;
    }
    .modal-scroll {
      max-height: min(560px, calc(100vh - 120px));
      overflow-y: auto;
    }

    .settings-section {
      margin-top: 18px;
      padding-top: 18px;
      border-top: 1px solid var(--border);
    }
    .settings-section:first-of-type {
      margin-top: 0;
      padding-top: 0;
      border-top: none;
    }
    .settings-section-title {
      font-size: 12px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: var(--text-dim);
      margin-bottom: 10px;
    }

    .log-popover {
      position: fixed;
      z-index: 19;
      width: min(420px, calc(100vw - 24px));
      max-height: min(280px, 40vh);
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 8px;
      box-shadow: 0 12px 40px rgba(0, 0, 0, 0.45);
      display: flex;
      flex-direction: column;
      pointer-events: auto;
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.12s, visibility 0.12s;
    }
    .log-popover.visible {
      opacity: 1;
      visibility: visible;
    }
    .log-popover-title {
      padding: 8px 12px;
      font-size: 12px;
      font-weight: 600;
      color: var(--text-dim);
      border-bottom: 1px solid var(--border);
      flex-shrink: 0;
    }
    .log-popover-body {
      flex: 1;
      overflow-y: auto;
      padding: 8px 12px;
      font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', monospace;
      font-size: 11px;
      line-height: 1.5;
    }
    .log-popover-body .log-line.stderr { color: var(--red); }
    .log-popover-body .log-line.system { color: var(--yellow); font-style: italic; }
    .log-popover-empty {
      color: var(--text-dim);
      font-style: italic;
    }
  </style>
</head>
<body>
  <header>
    <div style="display:flex;align-items:center;gap:16px;">
      <h1>xprocessmanager</h1>
      <div class="summary-bar" id="summary"></div>
    </div>
    <div class="header-actions">
      <button class="btn-ghost" onclick="openAddModal()">+ Add Process</button>
      <button class="btn-start" onclick="api('/api/start-all','POST')">Start All</button>
      <button class="btn-stop" onclick="api('/api/stop-all','POST')">Stop All</button>
      <button type="button" class="btn-ghost btn-settings-icon" onclick="openSettingsModal()" title="Settings — import, groups, environment" aria-label="Settings">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
      </button>
    </div>
  </header>

  <div class="container" id="main"></div>

  <div class="log-popover" id="logPopover" onmouseenter="cancelPopoverHide()" onmouseleave="schedulePopoverHide()">
    <div class="log-popover-title" id="logPopoverTitle">Logs</div>
    <div class="log-popover-body" id="logPopoverBody"></div>
  </div>

  <div class="log-panel hidden" id="logPanel">
    <div class="log-resize-handle" id="logResizeHandle"></div>
    <div class="log-header">
      <span id="logTitle">Logs</span>
      <span id="logLastRefresh" style="font-size:11px;color:var(--text-dim);margin-left:auto;margin-right:12px;"></span>
      <button class="btn-ghost" onclick="closeLog()">Close</button>
    </div>
    <div class="log-body" id="logBody"></div>
  </div>

  <div class="modal-overlay hidden" id="processModal" onclick="if(event.target===this)closeProcessModal()">
    <div class="modal">
      <h2 id="processModalTitle">Add Process</h2>
      <div class="form-group">
        <label>Name</label>
        <input type="text" id="f-name" placeholder="my-service" />
      </div>
      <div class="form-group">
        <label>Command</label>
        <input type="text" id="f-command" placeholder="pwsh, node, docker, npm..." />
      </div>
      <div class="form-group">
        <label>Arguments</label>
        <input type="text" id="f-args" placeholder="start_server.ps1  (space-separated)" />
        <div class="hint">Space-separated. Supports {ENV_KEY} templates</div>
      </div>
      <div class="form-group">
        <label>Working Directory</label>
        <input type="text" id="f-cwd" placeholder="{BASE_DIR}/my-project  (optional)" />
        <div class="hint">Use {ENV_KEY} to reference environment variables, e.g. {BASE_DIR}/src</div>
        <div id="f-cwd-resolved" class="hint" style="color:var(--purple);display:none;margin-top:4px;font-family:'SF Mono','Fira Code',monospace"></div>
      </div>
      <div class="form-group">
        <label>Group</label>
        <select id="f-group"></select>
      </div>
      <div class="modal-actions" style="justify-content:space-between">
        <div id="processModalDelete" style="display:none">
          <button class="btn-delete" onclick="removeFromModal()">Remove Process</button>
        </div>
        <div style="display:flex;gap:8px;margin-left:auto">
          <button class="btn-ghost" onclick="closeProcessModal()">Cancel</button>
          <button class="btn-start" id="processModalSubmit" onclick="submitProcessModal()">Add</button>
        </div>
      </div>
    </div>
  </div>

  <div class="modal-overlay hidden" id="settingsModal" onclick="if(event.target===this)closeSettingsModal()">
    <div class="modal modal-wide">
      <h2>Settings</h2>
      <div class="settings-tabs">
        <button class="settings-tab active" onclick="switchSettingsTab('general', this)">General</button>
        <button class="settings-tab" onclick="switchSettingsTab('advanced', this)">Advanced</button>
      </div>
      <div class="modal-scroll">
        <div id="settingsTabGeneral" class="settings-tab-content active">
          <div class="settings-section">
            <div class="settings-section-title">Import processes</div>
            <div class="env-note">Choose a JSON file in the same format as <code>processes.config.json</code> (an array of process definitions). Existing names are skipped.</div>
            <button type="button" class="btn-ghost" onclick="document.getElementById('importFile').click()">Import…</button>
            <input type="file" id="importFile" accept=".json" style="display:none" onchange="importProcesses(this)" />
          </div>
          <div class="settings-section">
            <div class="settings-section-title">Groups</div>
            <div class="env-note">Process groups, section order, and card border colors. Stored in <code>groups.config.json</code>. At least one group is required.</div>
            <div class="env-rows group-rows" id="groupRows"></div>
            <button type="button" class="btn-add-row" onclick="addGroupRow('')">+ Add group</button>
          </div>
          <div class="settings-section">
            <div class="settings-section-title">Environment variables</div>
            <div class="env-note">These variables are injected into all processes at startup. Restart running processes to pick up changes.</div>
            <div class="env-rows" id="envRows"></div>
            <button type="button" class="btn-add-row" onclick="addEnvRow('','')">+ Add Variable</button>
          </div>
        </div>
        <div id="settingsTabAdvanced" class="settings-tab-content">
          <div class="settings-section" style="margin-top:0;padding-top:0;border-top:none;">
            <div class="settings-section-title">Polling intervals</div>
            <div class="env-note">Control how frequently the UI fetches updates. Changes apply after saving (poll intervals apply immediately, port/maxLogLines require server restart).</div>
            <div class="setting-field">
              <label>Log poll interval (ms)</label>
              <input type="number" id="sys-logPollInterval" min="100" step="100" />
            </div>
            <div class="setting-field">
              <label>Status poll interval (ms)</label>
              <input type="number" id="sys-statusPollInterval" min="500" step="500" />
            </div>
            <div class="setting-field">
              <label>Popover poll interval (ms)</label>
              <input type="number" id="sys-popoverPollInterval" min="500" step="500" />
            </div>
          </div>
          <div class="settings-section">
            <div class="settings-section-title">Server</div>
            <div class="env-note">Requires server restart to take effect.</div>
            <div class="setting-field">
              <label>Port</label>
              <input type="number" id="sys-port" min="1" max="65535" />
            </div>
            <div class="setting-field">
              <label>Max log lines per process</label>
              <input type="number" id="sys-maxLogLines" min="50" step="50" />
            </div>
          </div>
        </div>
      </div>
      <div class="modal-actions">
        <button type="button" class="btn-ghost" onclick="closeSettingsModal()">Close</button>
        <button type="button" class="btn-start" onclick="saveSettings()">Save</button>
      </div>
    </div>
  </div>

  <script>
    let selectedProcess = null;
    let logSince = 0;
    let logAutoScroll = true;
    let lastSnapshot = '';

    async function api(url, method = 'GET', body = null) {
      const opts = { method };
      if (body) {
        opts.headers = { 'Content-Type': 'application/json' };
        opts.body = JSON.stringify(body);
      }
      const res = await fetch(url, opts);
      return res.json();
    }

    async function importProcesses(input) {
      const file = input.files[0];
      input.value = '';
      if (!file) return;
      try {
        const text = await file.text();
        const data = JSON.parse(text);
        if (!Array.isArray(data)) return alert('File must contain a JSON array of process configs.');
        const result = await api('/api/config/import', 'POST', data);
        if (result.error) return alert(result.error);
        const msgs = [];
        if (result.added.length) msgs.push(`Added: ${result.added.join(', ')}`);
        if (result.skipped.length) msgs.push(`Skipped: ${result.skipped.map(s => `${s.name} (${s.reason})`).join(', ')}`);
        alert(msgs.join('\n') || 'Nothing to import.');
        refresh(true);
      } catch (e) {
        alert('Invalid JSON file.');
      }
    }

    let editingProcess = null;

    function showResolvedCwd(cwd, resolvedCwd) {
      const el = document.getElementById('f-cwd-resolved');
      if (cwd && resolvedCwd && cwd !== resolvedCwd) {
        el.textContent = 'Resolved: ' + resolvedCwd;
        el.style.display = 'block';
      } else {
        el.style.display = 'none';
      }
    }

    function groupDefsToNames(defs) {
      if (!Array.isArray(defs)) return [];
      return defs.map((g) => (typeof g === 'string' ? g : g && g.name)).filter(Boolean);
    }

    async function fillGroupSelect(preferred) {
      const data = await api('/api/groups');
      const list = groupDefsToNames(data);
      const names = list.length ? list : ['other'];
      const sel = document.getElementById('f-group');
      sel.innerHTML = '';
      for (const g of names) {
        const opt = document.createElement('option');
        opt.value = g;
        opt.textContent = g;
        sel.appendChild(opt);
      }
      const pick = preferred && names.includes(preferred) ? preferred : names[0];
      sel.value = pick;
    }

    async function openAddModal() {
      editingProcess = null;
      document.getElementById('processModalTitle').textContent = 'Add Process';
      document.getElementById('processModalSubmit').textContent = 'Add';
      document.getElementById('f-name').disabled = false;
      ['f-name', 'f-command', 'f-args', 'f-cwd'].forEach(id => {
        document.getElementById(id).value = '';
      });
      await fillGroupSelect(null);
      showResolvedCwd(null, null);
      document.getElementById('processModalDelete').style.display = 'none';
      document.getElementById('processModal').classList.remove('hidden');
      document.getElementById('f-name').focus();
    }

    async function openEditModal(name) {
      const [config, procs] = await Promise.all([
        api(`/api/config/${name}`),
        api('/api/processes'),
      ]);
      if (config.error) return alert(config.error);
      const proc = procs.find(p => p.name === name);
      editingProcess = name;
      document.getElementById('processModalTitle').textContent = `Edit — ${name}`;
      document.getElementById('processModalSubmit').textContent = 'Save';
      document.getElementById('f-name').value = config.name;
      document.getElementById('f-name').disabled = false;
      document.getElementById('f-command').value = config.command || '';
      document.getElementById('f-args').value = (config.args || []).join(' ');
      document.getElementById('f-cwd').value = config.cwd || '';
      await fillGroupSelect(config.group);
      showResolvedCwd(config.cwd, proc?.resolvedCwd);
      document.getElementById('processModalDelete').style.display = 'block';
      document.getElementById('processModal').classList.remove('hidden');
      document.getElementById('f-command').focus();
    }

    function closeProcessModal() {
      document.getElementById('processModal').classList.add('hidden');
      showResolvedCwd(null, null);
      editingProcess = null;
    }

    async function submitProcessModal() {
      const name = document.getElementById('f-name').value.trim();
      const command = document.getElementById('f-command').value.trim();
      const argsRaw = document.getElementById('f-args').value.trim();
      const cwd = document.getElementById('f-cwd').value.trim();
      const group = document.getElementById('f-group').value;

      if (!name) return alert('Name is required.');
      if (!command) return alert('Command is required.');
      const args = argsRaw ? argsRaw.match(/(?:[^\s"']+|"[^"]*"|'[^']*')+/g).map(a => a.replace(/^["']|["']$/g, '')) : [];

      let result;
      if (editingProcess) {
        result = await api(`/api/config/${editingProcess}`, 'PUT', { name, command, args, cwd: cwd || undefined, group });
      } else {
        result = await api('/api/config', 'POST', { name, command, args, cwd: cwd || undefined, group });
      }
      if (result.error) return alert(result.error);

      if (editingProcess && name && name !== editingProcess && selectedProcess === editingProcess) {
        selectedProcess = name;
        document.getElementById('logTitle').textContent = `Logs — ${name}`;
      }

      closeProcessModal();
      refresh();
    }

    function switchSettingsTab(tab, btn) {
      document.querySelectorAll('.settings-tab').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.settings-tab-content').forEach(t => t.classList.remove('active'));
      btn.classList.add('active');
      document.getElementById(tab === 'advanced' ? 'settingsTabAdvanced' : 'settingsTabGeneral').classList.add('active');
    }

    async function openSettingsModal() {
      const [env, groupData, sys] = await Promise.all([api('/api/env'), api('/api/groups'), api('/api/system')]);
      document.getElementById('sys-logPollInterval').value = sys.logPollInterval || 500;
      document.getElementById('sys-statusPollInterval').value = sys.statusPollInterval || 3000;
      document.getElementById('sys-popoverPollInterval').value = sys.popoverPollInterval || 1500;
      document.getElementById('sys-port').value = sys.port || 1337;
      document.getElementById('sys-maxLogLines').value = sys.maxLogLines || 500;
      // Reset to General tab
      document.querySelectorAll('.settings-tab').forEach((t, i) => t.classList.toggle('active', i === 0));
      document.getElementById('settingsTabGeneral').classList.add('active');
      document.getElementById('settingsTabAdvanced').classList.remove('active');
      const container = document.getElementById('envRows');
      container.innerHTML = '';
      const entries = Object.entries(env);
      if (entries.length === 0) {
        addEnvRow('', '');
      } else {
        for (const [key, val] of entries) {
          addEnvRow(key, val);
        }
      }
      const gContainer = document.getElementById('groupRows');
      gContainer.innerHTML = '';
      const fallback = [
        { name: 'infra', color: '#a78bfa' },
        { name: 'frontend', color: '#60a5fa' },
        { name: 'backend', color: '#34d399' },
      ];
      const gList = Array.isArray(groupData) && groupData.length ? groupData : fallback;
      for (const g of gList) {
        if (typeof g === 'string') {
          addGroupRow(g, '#888888');
        } else if (g && g.name) {
          addGroupRow(g.name, g.color);
        }
      }
      document.getElementById('settingsModal').classList.remove('hidden');
    }

    function closeSettingsModal() {
      document.getElementById('settingsModal').classList.add('hidden');
    }

    function addEnvRow(key, val) {
      const container = document.getElementById('envRows');
      const row = document.createElement('div');
      row.className = 'env-row';
      row.innerHTML =
        `<input type="text" class="env-key" placeholder="KEY" value="${escHtml(key)}" />` +
        `<input type="text" class="env-val" placeholder="value" value="${escHtml(val)}" />` +
        `<button type="button" class="btn-remove-row" onclick="this.parentElement.remove()">&times;</button>`;
      container.appendChild(row);
      if (!key) row.querySelector('.env-key').focus();
    }

    function normalizeColorInput(hex) {
      if (!hex || typeof hex !== 'string') return '#888888';
      const s = hex.trim();
      if (/^#[0-9a-fA-F]{6}$/.test(s)) return s.toLowerCase();
      if (/^#[0-9a-fA-F]{3}$/.test(s)) {
        return `#${s[1]}${s[1]}${s[2]}${s[2]}${s[3]}${s[3]}`.toLowerCase();
      }
      return '#888888';
    }

    function addGroupRow(name, color) {
      const container = document.getElementById('groupRows');
      const row = document.createElement('div');
      row.className = 'env-row group-row';
      const c = normalizeColorInput(color || '#888888');
      row.innerHTML =
        `<input type="text" class="env-val group-name" style="flex:1" placeholder="group name" value="${escHtml(name || '')}" />` +
        `<input type="color" class="group-color" value="${escHtml(c)}" title="Border color" />` +
        `<button type="button" class="btn-remove-row" onclick="this.parentElement.remove()">&times;</button>`;
      container.appendChild(row);
      if (!name) row.querySelector('.group-name').focus();
    }

    function getGroupsFromRows() {
      const rows = document.querySelectorAll('#groupRows .group-row');
      const out = [];
      const seen = new Set();
      for (const row of rows) {
        const name = row.querySelector('.group-name').value.trim();
        const color = normalizeColorInput(row.querySelector('.group-color').value);
        if (!name) continue;
        if (seen.has(name)) {
          alert(`Duplicate group name: "${name}"`);
          return null;
        }
        seen.add(name);
        out.push({ name, color });
      }
      return out;
    }

    function escHtml(s) {
      return s.replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }

    function escapeAttr(s) {
      return String(s).replace(/&/g, '&amp;').replace(/"/g, '&quot;');
    }

    async function saveSettings() {
      const env = {};
      for (const row of document.querySelectorAll('#envRows .env-row')) {
        const key = row.querySelector('.env-key').value.trim();
        const val = row.querySelector('.env-val').value;
        if (key) env[key] = val;
      }
      const groups = getGroupsFromRows();
      if (!groups) return;
      if (groups.length === 0) return alert('At least one non-empty group is required.');
      const r1 = await api('/api/env', 'PUT', env);
      if (r1.error) return alert(r1.error);
      const r2 = await api('/api/groups', 'PUT', groups);
      if (r2.error) return alert(r2.error);
      const sysUpdate = {
        port: parseInt(document.getElementById('sys-port').value) || 1337,
        maxLogLines: parseInt(document.getElementById('sys-maxLogLines').value) || 500,
        logPollInterval: parseInt(document.getElementById('sys-logPollInterval').value) || 500,
        statusPollInterval: parseInt(document.getElementById('sys-statusPollInterval').value) || 3000,
        popoverPollInterval: parseInt(document.getElementById('sys-popoverPollInterval').value) || 1500,
      };
      const r3 = await api('/api/system', 'PUT', sysUpdate);
      if (r3.error) return alert(r3.error);
      closeSettingsModal();
      await applyPollIntervals();
      refresh(true);
    }

    async function removeProcess(name) {
      if (!confirm(`Remove "${name}" from config?`)) return;
      const result = await api(`/api/config/${name}`, 'DELETE');
      if (result.error) return alert(result.error);
      if (selectedProcess === name) closeLog();
      refresh();
    }

    async function removeFromModal() {
      if (!editingProcess) return;
      await removeProcess(editingProcess);
      closeProcessModal();
    }

    function formatUptime(ms) {
      if (!ms) return '-';
      const s = Math.floor(ms / 1000);
      if (s < 60) return `${s}s`;
      const m = Math.floor(s / 60);
      if (m < 60) return `${m}m ${s % 60}s`;
      const h = Math.floor(m / 60);
      return `${h}h ${m % 60}m`;
    }

    let popoverShowTimer = null;
    let popoverHideTimer = null;
    let popoverPollTimer = null;
    let popoverName = null;
    let popoverSince = 0;
    let popoverAnchorEl = null;

    function hideLogPopover() {
      clearTimeout(popoverShowTimer);
      popoverShowTimer = null;
      clearTimeout(popoverHideTimer);
      popoverHideTimer = null;
      if (popoverPollTimer) {
        clearInterval(popoverPollTimer);
        popoverPollTimer = null;
      }
      popoverName = null;
      popoverSince = 0;
      popoverAnchorEl = null;
      const pop = document.getElementById('logPopover');
      if (pop) pop.classList.remove('visible');
      const body = document.getElementById('logPopoverBody');
      if (body) body.innerHTML = '';
    }

    function schedulePopoverHide() {
      clearTimeout(popoverHideTimer);
      popoverHideTimer = setTimeout(() => {
        popoverHideTimer = null;
        hideLogPopover();
      }, 250);
    }

    function cancelPopoverHide() {
      clearTimeout(popoverHideTimer);
      popoverHideTimer = null;
    }

    function positionPopover(anchorEl) {
      const pop = document.getElementById('logPopover');
      const rect = anchorEl.getBoundingClientRect();
      const margin = 8;
      const w = pop.offsetWidth || 400;
      const h = pop.offsetHeight || 200;
      let left = rect.left;
      let top = rect.bottom + margin;
      if (left + w > window.innerWidth - 12) left = window.innerWidth - w - 12;
      if (left < 12) left = 12;
      if (top + h > window.innerHeight - 12) {
        top = rect.top - margin - h;
      }
      if (top < 12) top = 12;
      pop.style.left = left + 'px';
      pop.style.top = top + 'px';
    }

    async function fetchPopoverLogs() {
      if (!popoverName) return;
      const sinceBefore = popoverSince;
      const logs = await api(`/api/processes/${encodeURIComponent(popoverName)}/logs?since=${popoverSince}`);
      if (!Array.isArray(logs)) return;
      const body = document.getElementById('logPopoverBody');
      if (sinceBefore === 0) {
        body.innerHTML = '';
      }
      for (const entry of logs) {
        const div = document.createElement('div');
        div.className = `log-line ${entry.source}`;
        div.textContent = entry.text;
        body.appendChild(div);
        popoverSince = Math.max(popoverSince, entry.ts);
      }
      if (sinceBefore === 0 && logs.length === 0) {
        body.innerHTML = '<div class="log-popover-empty">No logs yet.</div>';
      }
      while (body.querySelectorAll('.log-line').length > 200) {
        body.removeChild(body.querySelector('.log-line'));
      }
      const lines = body.querySelectorAll('.log-line');
      if (lines.length) body.scrollTop = body.scrollHeight;
    }

    function openLogPopover(name, anchorEl) {
      hideLogPopover();
      popoverName = name;
      popoverSince = 0;
      popoverAnchorEl = anchorEl;
      document.getElementById('logPopoverTitle').textContent = `Logs — ${name}`;
      document.getElementById('logPopoverBody').innerHTML = '';
      document.getElementById('logPopover').classList.add('visible');
      requestAnimationFrame(() => {
        positionPopover(anchorEl);
        requestAnimationFrame(() => positionPopover(anchorEl));
      });
      fetchPopoverLogs();
      popoverPollTimer = setInterval(fetchPopoverLogs, window.__popoverPollInterval || 1500);
    }

    function onCardHoverEnter(name, card) {
      cancelPopoverHide();
      clearTimeout(popoverShowTimer);
      popoverShowTimer = setTimeout(() => {
        popoverShowTimer = null;
        openLogPopover(name, card);
      }, 1000);
    }

    function onCardHoverLeave() {
      clearTimeout(popoverShowTimer);
      popoverShowTimer = null;
      schedulePopoverHide();
    }

    function buildGroupColorMap(groupDefs) {
      const map = {};
      if (!Array.isArray(groupDefs)) return map;
      for (const g of groupDefs) {
        if (typeof g === 'object' && g && g.name) {
          map[g.name] = normalizeColorInput(g.color || '#4b5563');
        }
      }
      return map;
    }

    function renderProcesses(procs, groupDefs) {
      const main = document.getElementById('main');
      const groups = {};
      const counts = { running: 0, stopped: 0, errored: 0, stopping: 0 };

      for (const p of procs) {
        const g = p.group || 'other';
        if (!groups[g]) groups[g] = [];
        groups[g].push(p);
        if (counts[p.status] !== undefined) counts[p.status]++;
        else counts.stopped++;
      }

      document.getElementById('summary').innerHTML =
        `<span>Total: <span class="count">${procs.length}</span></span>` +
        `<span>Running: <span class="count running-count">${counts.running}</span></span>` +
        `<span>Stopped: <span class="count stopped-count">${counts.stopped + counts.stopping}</span></span>` +
        (counts.errored ? `<span>Errored: <span class="count errored-count">${counts.errored}</span></span>` : '');

      const orderNames = groupDefsToNames(groupDefs);
      const order = orderNames.length ? orderNames : ['infra', 'frontend', 'backend'];
      const colorMap = buildGroupColorMap(groupDefs);
      const defaultBorder = '#4b5563';

      const sorted = Object.entries(groups).sort((a, b) => {
        const ia = order.indexOf(a[0]);
        const ib = order.indexOf(b[0]);
        const va = ia === -1 ? 999 : ia;
        const vb = ib === -1 ? 999 : ib;
        if (va !== vb) return va - vb;
        return a[0].localeCompare(b[0]);
      });

      let html = '';
      for (const [group, items] of sorted) {
        html += `<div class="group-title">${group}</div><div class="process-grid">`;
        for (const p of items) {
          const uptime = p.status === 'running' && p.startedAt
            ? formatUptime(Date.now() - p.startedAt)
            : '-';
          const isSelected = selectedProcess === p.name;
          const gKey = p.group || 'other';
          const borderCol = colorMap[gKey] || defaultBorder;
          html += `
            <div class="card ${isSelected ? 'selected' : ''}" data-process-name="${escapeAttr(p.name)}" style="border-color:${escapeAttr(borderCol)}" onclick="selectLogFromCard(this)">
              <div class="card-header">
                <div class="card-name">
                  <span class="status-dot ${p.status}"></span>
                  ${p.name}
                </div>
                <div class="card-actions">
                  ${p.status === 'running'
                    ? `<button class="btn-stop" onclick="event.stopPropagation();api('/api/processes/${p.name}/stop','POST').then(refresh)">Stop</button>
                       <button class="btn-restart" onclick="event.stopPropagation();api('/api/processes/${p.name}/restart','POST').then(()=>{selectLog('${p.name}');refresh(true)})">Restart</button>`
                    : `<button class="btn-start" onclick="event.stopPropagation();api('/api/processes/${p.name}/start','POST').then(()=>{selectLog('${p.name}');refresh(true)})">Start</button>`
                  }
                  <button class="btn-gear" onclick="event.stopPropagation();openEditModal('${p.name}')"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg></button>
                </div>
              </div>
              <div class="card-meta">
                <span>PID: ${p.pid || '-'}</span>
                <span>Uptime: ${uptime}</span>
                ${p.branch ? `<span class="branch-tag">${p.branch}</span>` : ''}
              </div>
            </div>`;
        }
        html += '</div>';
      }
      hideLogPopover();
      main.innerHTML = html;
      main.querySelectorAll('.card').forEach((card) => {
        const n = card.getAttribute('data-process-name');
        if (n == null) return;
        card.addEventListener('mouseenter', () => onCardHoverEnter(n, card));
        card.addEventListener('mouseleave', onCardHoverLeave);
      });

      main.style.paddingBottom = selectedProcess ? (logPanelHeight + 20) + 'px' : '';
    }

    async function refresh(force) {
      const [procs, groupDefs] = await Promise.all([
        api('/api/processes'),
        api('/api/groups'),
      ]);
      const defs = Array.isArray(groupDefs) && groupDefs.length
        ? groupDefs
        : [
            { name: 'infra', color: '#a78bfa' },
            { name: 'frontend', color: '#60a5fa' },
            { name: 'backend', color: '#34d399' },
          ];
      const snapshot = JSON.stringify({
        procs: procs.map(p => ({
          name: p.name, status: p.status, pid: p.pid, group: p.group, branch: p.branch,
        })),
        groups: defs,
      }) + '|' + selectedProcess;
      if (!force && snapshot === lastSnapshot) return;
      lastSnapshot = snapshot;
      renderProcesses(procs, defs);
    }

    function selectLogFromCard(el) {
      const name = el.getAttribute('data-process-name');
      selectLog(name);
    }

    function selectLog(name) {
      hideLogPopover();
      if (selectedProcess === name) {
        closeLog();
        return;
      }
      selectedProcess = name;
      logSince = 0;
      document.getElementById('logBody').innerHTML = '';
      document.getElementById('logTitle').textContent = `Logs — ${name}`;
      document.getElementById('logPanel').classList.remove('hidden');
      fetchLogs();
      refresh();
    }

    function closeLog() {
      selectedProcess = null;
      document.getElementById('logPanel').classList.add('hidden');
      refresh();
    }

    async function fetchLogs() {
      if (!selectedProcess) return;
      const logs = await api(`/api/processes/${selectedProcess}/logs?since=${logSince}`);
      const body = document.getElementById('logBody');

      for (const entry of logs) {
        const div = document.createElement('div');
        div.className = `log-line ${entry.source}`;
        div.textContent = entry.text;
        body.appendChild(div);
        logSince = Math.max(logSince, entry.ts);
      }

      if (logAutoScroll && logs.length > 0) {
        body.scrollTop = body.scrollHeight;
      }

      const now = new Date();
      document.getElementById('logLastRefresh').textContent = 'Last refresh: ' + now.toLocaleTimeString();
    }

    const logBodyEl = document.getElementById('logBody');
    logBodyEl.addEventListener('scroll', () => {
      const { scrollTop, scrollHeight, clientHeight } = logBodyEl;
      logAutoScroll = scrollHeight - scrollTop - clientHeight < 40;
    });

    let logPanelHeight = 300;
    const logPanel = document.getElementById('logPanel');
    const resizeHandle = document.getElementById('logResizeHandle');

    function applyLogPanelHeight(h) {
      logPanelHeight = Math.max(120, Math.min(h, window.innerHeight - 60));
      logPanel.style.height = logPanelHeight + 'px';
      document.getElementById('main').style.paddingBottom = selectedProcess ? (logPanelHeight + 20) + 'px' : '';
    }

    resizeHandle.addEventListener('mousedown', (e) => {
      e.preventDefault();
      logPanel.classList.add('dragging');
      const onMove = (ev) => applyLogPanelHeight(window.innerHeight - ev.clientY);
      const onUp = () => {
        logPanel.classList.remove('dragging');
        document.removeEventListener('mousemove', onMove);
        document.removeEventListener('mouseup', onUp);
      };
      document.addEventListener('mousemove', onMove);
      document.addEventListener('mouseup', onUp);
    });

    resizeHandle.addEventListener('touchstart', (e) => {
      e.preventDefault();
      logPanel.classList.add('dragging');
      const onMove = (ev) => applyLogPanelHeight(window.innerHeight - ev.touches[0].clientY);
      const onEnd = () => {
        logPanel.classList.remove('dragging');
        document.removeEventListener('touchmove', onMove);
        document.removeEventListener('touchend', onEnd);
      };
      document.addEventListener('touchmove', onMove);
      document.addEventListener('touchend', onEnd);
    });

    window.addEventListener('resize', () => {
      const pop = document.getElementById('logPopover');
      if (popoverAnchorEl && pop.classList.contains('visible')) {
        positionPopover(popoverAnchorEl);
      }
    });

    let refreshTimer, logTimer;
    async function applyPollIntervals() {
      const sys = await api('/api/system');
      window.__popoverPollInterval = sys.popoverPollInterval || 1500;
      clearInterval(refreshTimer);
      clearInterval(logTimer);
      refreshTimer = setInterval(refresh, sys.statusPollInterval || 3000);
      logTimer = setInterval(fetchLogs, sys.logPollInterval || 500);
    }
    refresh();
    applyPollIntervals();
  </script>
</body>
</html>
